# Mission Control (AgentIQ) Environment Variables
# Copy this file to .env and fill in the values.

# Database connection (Docker Compose provides this internally)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/missioncontrol

# JWT secret for authentication tokens
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# OpenClaw webhook secret (leave empty if not using OpenClaw)
OPENCLAW_WEBHOOK_SECRET=

# Node environment — must be "production" for the JWT guard to activate
NODE_ENV=development
