# Hermes Bridge Dockerfile
# Combines Node.js (for the bridge script) with Python + Hermes CLI

FROM node:20-alpine

# Install Python, pip, and venv for Hermes CLI
RUN apk add --no-cache python3 py3-pip python3-venv

# Create and activate virtual environment for Hermes
RUN python3 -m venv /opt/hermes-venv && \
    /opt/hermes-venv/bin/pip install hermes-agent

# Add Hermes to PATH
ENV PATH="/opt/hermes-venv/bin:$PATH"

# Enable pnpm
RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app

# Copy package files
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/api/package.json apps/api/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy the rest of the code
COPY . .

# Verify installations
RUN echo "Node: $(node --version)" && \
    echo "Python: $(python3 --version)" && \
    echo "Hermes: $(hermes --version 2>/dev/null || echo 'Hermes CLI installed')"

# The bridge will be started by docker-compose command
CMD ["sh", "-c", "echo 'Hermes Bridge container ready' && tail -f /dev/null"]